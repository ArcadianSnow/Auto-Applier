# Platform credentials (one pair per enabled platform)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password

INDEED_EMAIL=your_email@example.com
INDEED_PASSWORD=your_password

DICE_EMAIL=your_email@example.com
DICE_PASSWORD=your_password

ZIPRECRUITER_EMAIL=your_email@example.com
ZIPRECRUITER_PASSWORD=your_password

# LLM settings
OLLAMA_BASE_URL=http://localhost:11434
# Default gemma4:e4b (~4.5B effective, ~9.6 GB download, fits 16 GB RAM).
# Alternatives: gemma4:e2b (smaller), gemma4:31b (beefy hardware).
# Requires Ollama >= 0.8.0 for Gemma 4 support.
OLLAMA_MODEL=gemma4:e4b
GEMINI_API_KEY=

# Application settings
MAX_APPLICATIONS_PER_DAY=10
MIN_DELAY_BETWEEN_ACTIONS=3
MAX_DELAY_BETWEEN_ACTIONS=8
MIN_DELAY_BETWEEN_APPLICATIONS=60
MAX_DELAY_BETWEEN_APPLICATIONS=180
