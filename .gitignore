# Credentials
.env

# Data files (contain personal info) — ignore the ENTIRE data dir (user data / PII).
# Catch-all first so NOTHING under data/ is ever committed (a stray .md slipped past
# the specific rules below once); the specific entries are kept for clarity.
/data/
data/browser_profile/
data/browser_profile_chromium/
data/cover_letters/
data/cache/
data/profiles/
data/research/
data/.backups/
data/*.csv
data/*.json
data/.schema_version.json
data/logs/

# Resumes (user uploads)
data/resumes/

# v3 data dir — SQLite DBs, artifacts, persistent Chrome profile, backups, diagnostics.
# The entire v3 data tree (default data/v3/, relocatable via AV3_DATA_DIR) is user data
# and must never be committed.
data/v3/

# Playwright-MCP scratch logs
.playwright-mcp/

# Scheduler lock
.claude/scheduled_tasks.lock

# CLI-generated export artifacts
auto_applier_export.json

# Local-state for the auto-updater (commit SHA the user is on)
.version

# update.bat / setup.bat verbose output (errors during install)
update.log
setup.log

# PyInstaller
dist/
build/
*.spec

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# IDE
.vscode/
.idea/

# Build-time generated by scripts/write_version.py for zip releases.
# Dev tree uses live git for version detection; gitignored so dev
# commits don't accumulate VERSION-file noise.
VERSION

# Inno Setup installer artifacts. The compiled .exe lands here;
# we don't want multi-MB installer binaries in git history. Build
# them via `python installer/build_installer.py`.
installer/Output/
installer/icon.ico

# OS
.DS_Store
Thumbs.db
.claude/unstuck/

.claude/unstuck/ACTIVE
